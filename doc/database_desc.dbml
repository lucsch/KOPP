Table records {
  record_id integer [primary key]
  date datetime
  hr_base integer
  hr_maj integer
  annual integer
  vac integer
  comment varchar
}

Table tags {
  id integer [primary key]
  desc varchar
}

Table tagsmix {
  record_id integer
  tag_id integer
}

Ref: "tagsmix"."record_id" < "records"."record_id"

Ref: "tagsmix"."tag_id" < "tags"."id"